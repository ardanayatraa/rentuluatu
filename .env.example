## Environment variables for Wavy Rental (example)
## Copy this file to `.env` and fill in your values.
## NOTE: Do NOT commit `.env` to git.

# Google Drive backup OAuth
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# Recovery key encryption (wajib untuk production, minimal 16 karakter)
BACKUP_RECOVERY_PASSWORD=REPLACE_WITH_STRONG_RANDOM_PASSWORD

# License signing secret (wajib untuk production, minimal 32 karakter)
WAVY_LICENSE_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS

# App version (normally sourced from package.json in build)
VITE_APP_VERSION=1.0.39
